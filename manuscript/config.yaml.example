# template_newspaper - manuscript configuration template
#
# Copy this file to config.yaml in a fork. This file configures the standard
# repository manuscript render. The newspaper PDF itself is generated from the
# content/ YAML files by project scripts during analysis.

paper:
  title: "Your Data-Driven Newspaper Layout Engine"
  subtitle: "A reproducible publishing exemplar"
  version: "1.0.0"
  date: ""

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"
    email: "you@example.edu"
    affiliation: "Your Institution"
    corresponding: true

publication:
  github_repository: ""
  doi: ""
  version_doi: ""
  version_record: ""
  year: "2026"

keywords:
  - "newspaper layout"
  - "typography"
  - "reproducible publishing"

metadata:
  license: "MIT"
  language: "en"

manuscript_dir: "manuscript"

render:
  formats:
    pdf: true
    html: true
    slides: false
    docx: false
    epub: false
